					window.location.href = '/MyAccount/?from=url&url=' + encodeURIComponent(window.location.href.replace(window.location.origin, '')) + '&dn=' + window.location.host;
				});
			

		if ('False' == 'True') {
            $('#loggedOutToolbarSignInButton').hide();
		}
    })
</script>
