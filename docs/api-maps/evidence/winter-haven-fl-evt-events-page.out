                <div class="form-group required">
                    <label class="control-label" for="form--name">Page name:</label>
                    <input type="text" id="form--name" name="form-name" class="form-control" value="" />
                </div>
                <p class="form-name-desc">Must be written in English, only letters and numbers are accepted. Use “_” for separation.</p>
                <p class="form-name-error text-danger hidden"></p>
