    <div class="control-buttons">
            <button class="btn btn-upload mobile-hide" data-action="file"><svg aria-hidden="true" viewBox="0 0 16 16"><use xlink:href="/static-icons/svg/icon-upload.svg#icon"></use></svg>&nbsp;Select Image</button>
            <button class="btn btn-upload mobile-show" data-action="file"><svg aria-hidden="true" viewBox="0 0 16 16"><use xlink:href="/static-icons/svg/icon-upload.svg#icon"></use></svg></button>
            <button type="button" class="btn btn-reset" title="Reset" aria-label="Reset"><svg aria-hidden="true" viewBox="0 0 16 16"><use xlink:href="/static-icons/svg/icon-eraser.svg#icon"></use></svg></button>
            <button type="button" class="btn btn-rotate" title="{@:Rotate@}" aria-label="{@:Rotate@}"><svg aria-hidden="true" viewBox="0 0 16 16"><use xlink:href="/static-icons/svg/icon-rotate.svg#icon"></use></svg></button>
            <select name="format">
<option value="image/png" selected>PNG</option>
<option value="image/jpeg">JPEG</option>
</select>
    </div>
</div>
<div class="footer">
    <button class="btn btn-main" data-action="submit">Upload</button>
    <button class="btn btn-dark" data-action="cancel">Cancel</button>
</div>
</form>
</div>
</div>
</dialog></div>
