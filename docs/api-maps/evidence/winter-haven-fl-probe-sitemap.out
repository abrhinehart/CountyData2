    <button type="button" class="wh-translate__reset" aria-label="Reset translation" title="Reset to English">
      Reset
    </button>
  </div>
</section>

<style>
  /* --- Brand tokens for dark footer --- */
  :root{
    --wh-font: "Source Sans Pro", "Source Sans 3", Calibri, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial, "Noto Sans", sans-serif;
    --wh-text-light: #f8fafc;         /* footer text on dark */
    --wh-muted: #cbd5e1;              /* secondary text on dark */
    --wh-primary: #7cc0ff;            /* accent for icon/focus */
    --wh-btn: #1363df;                /* brand blue for Reset */
    --wh-btn-text: #ffffff;
    --wh-border-light: rgba(255,255,255,.25);
    --wh-radius: 10px;
  }

  /* Container (inherits the footer's dark bg) */
  .wh-translate--footer{ padding:12px 16px; }
  .wh-translate__inner{
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    gap: 12px;
    align-items: center;
    justify-content: flex-start; /* TOP-LEFT ALIGNMENT */
    flex-wrap: wrap;
    text-align: left;
  }

  .wh-translate__label{
    display: inline-flex; align-items: center; gap: 8px;
    font-family: var(--wh-font);
    font-weight: 600; font-size: 14px; letter-spacing: .2px;
    color: var(--wh-text-light);
    white-space: nowrap;
  }
  .wh-translate__icon{ fill: var(--wh-primary); }

  /* Google dropdown — light control for contrast on dark footer */
  #google_translate_element .goog-te-gadget{ font-size: 0; } /* hides duplicate "Translate" text */
  #google_translate_element .goog-te-gadget select,
  .goog-te-combo{
    font-family: var(--wh-font) !important;
    font-size: 14px !important;
    padding: 6px 10px !important;
    border: 1px solid var(--wh-border-light) !important;
    border-radius: var(--wh-radius) !important;
    background: #ffffff !important;
    color: #0f172a !important;
    line-height: 1.2 !important;
    height: 34px !important;
    display: inline-block !important;
    opacity: 1 !important; visibility: visible !important; pointer-events: auto !important;
  }

  .wh-translate__reset{
    font-family: var(--wh-font); font-size: 13px; font-weight: 700;
    padding: 6px 12px; border-radius: var(--wh-radius);
    border: 1px solid var(--wh-btn);
    background: var(--wh-btn); color: var(--wh-btn-text);
    cursor: pointer; transition: transform .04s ease, opacity .15s ease;
  }
  .wh-translate__reset:hover{ opacity: .95; }
  .wh-translate__reset:active{ transform: translateY(1px); }

  /* Make Google’s language menu open above everything */
  .goog-te-menu-frame{ z-index: 2147483647 !important; }
  .goog-te-menu2{ max-height: 70vh !important; overflow: auto !important; }

  /* Prevent Google top banner from shifting layout */
  body .goog-te-banner-frame{ display: none !important; }
  body{ top: 0 !important; }

  /* A11y focus */
  .goog-te-combo:focus,
  .wh-translate__reset:focus{
    outline: 2px solid var(--wh-primary);
    outline-offset: 2px;
  }

  @media (max-width:520px){
    #google_translate_element .goog-te-gadget select{ width: 100%; }
  }
</style>

<script>
  // Initialize Google Translate
  function googleTranslateElementInit(){
    new google.translate.TranslateElement({
      pageLanguage: 'en',
      includedLanguages: 'en,es,ht,fr,pt,vi,ru,zh-CN',
      layout: google.translate.TranslateElement.InlineLayout.SIMPLE,
      autoDisplay: false
    }, 'google_translate_element');
  }

  // Reset to English across the site (clears the cookie and reloads)
  function whResetTranslate(){
    try{
      var domain = location.hostname.replace(/^www\./,'');
      document.cookie = 'googtrans=;expires=Thu, 01 Jan 1970 00:00:00 GMT;path=/;domain=.' + domain;
      document.cookie = 'googtrans=;expires=Thu, 01 Jan 1970 00:00:00 GMT;path=/';
      location.reload();
    }catch(e){ location.reload(); }
  }

  document.addEventListener('DOMContentLoaded', function(){
    var btn = document.querySelector('.wh-translate__reset');
    if(btn) btn.addEventListener('click', whResetTranslate);
  });

  // Load Google Translate script over HTTPS (safe if already present)
  (function loadGT(){
    if(window.google && window.google.translate){ googleTranslateElementInit(); return; }
    var s = document.createElement('script');
    s.src = 'https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit';
    s.async = true; document.head.appendChild(s);
  })();
</script>

