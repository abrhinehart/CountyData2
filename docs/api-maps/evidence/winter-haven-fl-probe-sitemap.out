<section class="wh-translate wh-translate--footer" aria-label="Translate this page">
  <div class="wh-translate__inner">
    <div class="wh-translate__label">
      <svg class="wh-translate__icon" viewbox="0 0 24 24" width="18" height="18" aria-hidden="true">
        <path d="M12 2a10 10 0 1 0 .001 20.001A10 10 0 0 0 12 2Zm0 2c1.73 0 3.33.55 4.63 1.48-.33.43-.69.86-1.09 1.26A10.9 10.9 0 0 0 13 6.2V8h-2V6.2a9 9 0 0 1-2.54.64c-.4-.4-.76-.83-1.09-1.26A7.98 7.98 0 0 1 12 4Zm-7.74 8c.12-1.27.54-2.45 1.2-3.48.53.63 1.14 1.2 1.82 1.7A10.93 10.93 0 0 0 6.1 12H4.26ZM9 12c.1-.7.27-1.38.5-2H14.5c.23.62.4 1.3.5 2H9Zm8.9 0c-.16.96-.49 1.87-.92 2.72.68.5 1.29 1.06 1.82 1.7.66-1.03 1.08-2.2 1.2-3.48H17.9ZM7.3 16.2c.77.98 1.72 1.78 2.79 2.33V20a8 8 0 0 1-5.83-2.64c.33-.43.69-.86 1.09-1.26.33.04.65.07.98.1l.97.01ZM12 18c.86-.4 1.64-1.07 2.3-2h2.15c-.97 1.3-2.23 2.28-3.7 2.82V18h-.75ZM11 20v-1.48a9.9 9.9 0 0 1-3.44-2.52 25.4 25.4 0 0 1-2.48-.02A8 8 0 0 0 11 20Z"></path>
      </svg>
      <span id="wh-translate-label">Translate</span>
